#include <stdio.h>

int main()
{
    int mark;

    printf("Enter mark: ");
    scanf("%d", &mark);

    if(mark >= 80)
    {
        printf("Distinction\n");
    }
    else if(mark >= 60)
    {
        printf("First Class\n");
    }
    else if(mark >= 40)
    {
        printf("Pass\n");
    }
    else
    {
        printf("Fail\n");
    }

    return 0;
}
